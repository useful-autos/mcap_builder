@PACKAGE_INIT@

find_package(PkgConfig REQUIRED)
pkg_check_modules(LZ4 REQUIRED IMPORTED_TARGET liblz4)
pkg_check_modules(ZSTD REQUIRED IMPORTED_TARGET libzstd)

include ( "${CMAKE_CURRENT_LIST_DIR}/mcap-targets.cmake" )
